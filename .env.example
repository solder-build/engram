# Engram — Autonomous DeFi Treasury Agent
# Copy to .env and fill in values

# BIP-39 seed phrase for wallet derivation (leave empty to auto-generate)
ENGRAM_SEED_PHRASE=

# RPC endpoints (defaults provided for testnets)
ETH_SEPOLIA_RPC=https://rpc.sepolia.org
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Cortex API
CORTEX_API_URL=https://cortex-api-staging-871482515924.asia-southeast1.run.app

# Agent configuration
AGENT_INTERVAL=30
AGENT_DRY_RUN=false
AGENT_DEMO_MODE=false

# Strategy thresholds
IDLE_USDT_THRESHOLD=100
HEALTH_FACTOR_TARGET=1.5
ANOMALY_ZSCORE_THRESHOLD=2.5

# USDT token address on Sepolia (Aave testnet USDT)
USDT_SEPOLIA_ADDRESS=0xaA8E23Fb1079EA71e0a56F48a2aA51851D8433D0
